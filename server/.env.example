# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB connection string
# Option A — MongoDB Atlas (cloud, recommended)
#   1. Go to https://cloud.mongodb.com → create free cluster
#   2. Click "Connect" → "Drivers" → copy the URI
#   3. Replace <username>, <password>, <dbname>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/akash-trainer?retryWrites=true&w=majority

# Option B — Local MongoDB (if installed locally)
# MONGO_URI=mongodb://localhost:27017/akash-trainer

# Port the Express server listens on
PORT=4000
